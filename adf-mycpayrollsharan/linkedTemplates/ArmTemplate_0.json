		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-mycpayrollsharan"
		},
		"ls_adls_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adls'"
		},
		"ls_sqlsb_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_sqlsb'"
		},
		"ls_synapse_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_synapse'"
		},
		"ls_adls_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsnycpayrollsharanv.dfs.core.windows.net/"
		},
		"ls_sqlsb_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sqlserver-sharan.database.windows.net"
		},
		"ls_sqlsb_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "db_nycpayroll"
		},
		"ls_sqlsb_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "azureadmin"
		},
		"ls_synapse_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "synapse-nycpayrollsharan.sql.azuresynapse.net"
		},
		"ls_synapse_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sqlpool1"
		},
		"ls_synapse_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "azureadmin"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
