				"typeProperties": {
					"server": "[parameters('ls_sqlsb_properties_typeProperties_server')]",
					"database": "[parameters('ls_sqlsb_properties_typeProperties_database')]",
					"encrypt": "mandatory",
					"trustServerCertificate": false,
					"authenticationType": "SQL",
					"userName": "[parameters('ls_sqlsb_properties_typeProperties_userName')]",
					"password": {
						"type": "SecureString",
